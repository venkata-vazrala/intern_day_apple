        {"name": "Binary Signing", "weight": 0.4, "definition_of_done": "Image signed successfully", "type": "manual", "owner_team": "Build Automation"}
      ]
    },
    {
      "name": "Test",
      "weight": 0.4,
      "owner_team": "Validation",
      "type": "manual",
      "substages": [
        {"name": "Unit Tests", "weight": 0.3, "definition_of_done": "All tests passed", "type": "auto", "endpoint": "/api/checks/unit_tests/", "owner_team": "Validation"},
        {"name": "Integration Tests", "weight": 0.7, "definition_of_done": "All integrations verified", "type": "manual", "owner_team": "Validation"}
